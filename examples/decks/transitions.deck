{script:whatisatransition.0}
on click do
 local t:()
 t.Prev:"SlideRight"
 t.Next:"SlideLeft"
 t.Index:"BoxOut"
 go[me.text t[me.text] 15]
end
{end}

{script:whatisatransition.1}
on view do
 d:120
 t:1&(d%sys.frame)/(d/3)-1
 c1:if 2%floor sys.frame/d a else b end
 c2:if 2%floor sys.frame/d b else a end
 me.clear[]
 transition[].SlideRight[me c1.copy[] c2.copy[] t]
end
{end}

