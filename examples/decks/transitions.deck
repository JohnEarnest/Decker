{card:tweening}
script:"tweening.0"
{widgets}
button1:{"type":"button","size":[60,20],"pos":[442,312],"script":"whatisatransition.0","text":"Next","style":"rect"}
button2:{"type":"button","size":[60,20],"pos":[10,312],"script":"whatisatransition.0","text":"Prev","style":"rect"}
title:{"type":"field","size":[492,17],"pos":[10,22],"locked":1,"font":"menu","show":"invert","border":1,"align":"center","value":"Background: Tweening"}
button3:{"type":"button","size":[60,20],"pos":[78,312],"script":"whatisatransition.0","text":"Index","style":"rect"}
field1:{"type":"field","size":[240,145],"pos":[262,47],"locked":1,"border":0,"value":{"text":["In the context of a transition function, \"tweening\" is the process of creating smooth variations between our initial and final frame based on a number that varies between 0 and 1.\n\nThe simplest mathematical tool for tweening is linear interpolation, or \"lerp[]\". You can vary the position, scale, rotation, or other properties of shapes drawn on a canvas by giving lerp[] a tweening value and two \"anchors\" to vary between. Try modifying this example and scrubbing the slider to see the effects.\n\nThe ","ease"," module contains a variety of more complex tools that work in the same basic way. "],"font":["","",""],"arg":["","http://beyondloom.com/decker/ease.html",""]}}
ex1:{"type":"field","size":[243,146],"pos":[10,46],"script":"tweening.1","style":"code","value":"on lerp t a b do\n a+t*b-a\nend\n\nc.clear[]\nc.rect[\n lerp[t.value (100,10) ( 20,55)]\n lerp[t.value (  5, 5) ( 30,30)]\n \"center\"\n]"}
t:{"type":"slider","size":[144,25],"pos":[186,291],"script":"canvasdrawing.1","interval":[0,1],"value":0.4,"step":0.05}
c:{"type":"canvas","size":[119,74],"pos":[198,211],"locked":1,"volatile":1,"scale":1}
tv:{"type":"field","size":[144,14],"pos":[185,319],"locked":1,"volatile":1,"border":0,"align":"center"}

{script:tweening.0}
on view do
 tv.text:"tweening value %3.2f" format t.value
 eval[ex1.text () 1]
end
{end}

{script:tweening.1}
on change do
 view[]
end
{end}

{card:compositingtransitions}
{widgets}
button1:{"type":"button","size":[60,20],"pos":[442,312],"script":"whatisatransition.0","text":"Next","style":"rect"}
button2:{"type":"button","size":[60,20],"pos":[10,312],"script":"whatisatransition.0","text":"Prev","style":"rect"}
title:{"type":"field","size":[492,17],"pos":[10,22],"locked":1,"font":"menu","show":"invert","border":1,"align":"center","value":"A Complete Transition Function"}
button3:{"type":"button","size":[60,20],"pos":[78,312],"script":"whatisatransition.0","text":"Index","style":"rect"}
field1:{"type":"field","size":[222,259],"pos":[280,47],"locked":1,"border":0,"value":"Now we're ready to put the pieces together and write a complete transition function.\n\nWe draw a centered diamond on the canvas \"c\", scaled with a lerp[] to fill the canvas when the tween value \"t\" is 1. Having thus prepared a mask, we can use canvas.merge[] to composite together screenshots of the old card \"a\" and the new card \"b\".\n\nTry some variations. How could you reverse the direction of the animation? Add rotation? Can you simplify this to remove the need for lerp[]?\n\nCan you use this as a starting point to replicate the \"StarIn\" transition from PublicTransit?"}
ex1:{"type":"field","size":[259,174],"pos":[10,49],"style":"code","value":"on lerp t a b do\n a+t*b-a\nend\n\non diamond pos size do\n flip pos+size*flip unit 2*pi*(range 4)/4\nend\n\non DiamondIn c a b t do\n c.poly[diamond[\n   c.size/2\n   lerp[t 0 (max c.size)]\n ]]\n c.merge[a b]\nend"}
c_mask:{"type":"canvas","size":[85,57],"pos":[34,243],"locked":1,"animated":1,"volatile":1,"script":"compositingtransitions.0","show":"transparent","scale":1}
a:{"type":"canvas","size":[85,57],"pos":[249,264],"locked":1,"show":"none","image":"%%IMG3AFUAOQSwyUmrvTjrzbv/YCiOZGmeaKqubOu+cCzPFmADdH7dt+43PN4vF+wNZUXh8ZVULltN43MVdU5PVeuVlA1uS93idxQFJsehsuSM9qjX7PamWXnLd3EK/Y7Z18R8f4B4XoF1eYeDhn6EhYZmio1SgYx9kXeVkpOYYZ2LnZ6UoGGfo118pqFtqaporKSriB2ZU7Rzsk+2HLo/vBq+RLgfwr3Es8bBjlzINMy7l0POt8q5WsvU1Tgp0o+Wm90i3+Dj5OXm5+jp6mgR"}
b:{"type":"canvas","size":[85,57],"pos":[254,271],"locked":1,"show":"none","image":"%%IMG3AFUAOQQwyUmrvTjrzbv/YCiOZGmeaKqubOu+cCzPdG3fZKDvPA7zQKBvFSwKhzmjsocULZ+6ZggKlYKoT+sHOylqPdmK98sxYszkzfiCTmfWYribHaTL5/GjJIw/1xNVfW91WIVfhYhtSImMekONkFFNkZCTlIyWl4mLiFN3NXwlnzSKJ6OkfymnM6tXrTGlTkqZjrKztDuiS1avFlRavXtcwKm+mGSxlWlol3iawTjPTH3SghTN1nnD2YO/3GU9td9qkuPm5+jp6uszEQ=="}
field3:{"type":"field","size":[85,14],"pos":[34,229],"locked":1,"border":0,"align":"center","value":"mask only"}
c_full:{"type":"canvas","size":[85,57],"pos":[142,243],"locked":1,"volatile":1,"show":"transparent","scale":1}
field2:{"type":"field","size":[85,14],"pos":[142,229],"locked":1,"border":0,"align":"center","value":"with images"}

{script:compositingtransitions.0}
on view do
 f:eval[ex1.text () 1].value
 d:120
 t:1&(d%sys.frame)/d-1
 
 c_mask.clear[]
 f[c_mask image[c_mask.size] image[c_mask.size].map[0 dict 1] t]
 
 c_full.clear[]
 f[c_full a.copy[] b.copy[] t]
end
{end}

{card:texturemappedtheory}
script:"canvasdrawing.0"
{widgets}
button1:{"type":"button","size":[60,20],"pos":[442,312],"script":"whatisatransition.0","text":"Next","style":"rect"}
button2:{"type":"button","size":[60,20],"pos":[10,312],"script":"whatisatransition.0","text":"Prev","style":"rect"}
title:{"type":"field","size":[492,17],"pos":[10,22],"locked":1,"font":"menu","show":"invert","border":1,"align":"center","value":"Texture-Mapped Transitions (Theory)"}
button3:{"type":"button","size":[60,20],"pos":[78,312],"script":"whatisatransition.0","text":"Index","style":"rect"}
field1:{"type":"field","size":[223,259],"pos":[279,47],"locked":1,"border":0,"value":"For some kinds of effect, it would be too computationally intensive to draw a mask texture from scratch for every transition frame.\n\nThe canvas.merge[] function will always tile its input images to match the dimensions of the canvas. Thus, if we merge[] a single image onto a blank canvas, we can efficiently fill the entire canvas in one step.\n\nIf we prepare an image in advance with up to 256 levels of \"gray\" in its pixels, we could compare those levels against a threshold in order to efficiently extract a 0/1 mask, which can then be used to merge our card screenshots as usual.\n\nIt's possible to create a grayscale lookup texture for this sort of effect as large as an entire card, but this can take up a great deal of space as well as tie an effect to a specific deck size."}
c:{"type":"canvas","size":[80,77],"pos":[36,225],"locked":1,"volatile":1,"scale":1}
threshold:{"type":"slider","size":[100,25],"pos":[142,252],"script":"canvasdrawing.1","interval":[0,5],"value":2,"style":"compact"}
ex1:{"type":"field","size":[260,168],"pos":[10,49],"script":"canvasdrawing.1","style":"code","value":"# a small repeating texture:\np:0,1,2,3,4,3,2,1\ni:image[(count p),1]\ni.pixels:p\n\n# tile the texture onto the canvas:\nc.clear[]\nc.merge[i]\n\n# apply a threshold:\na:image[1,1]               # all pattern 0\nb:image[1,1].map[0 dict 1] # all pattern 1\nt:threshold.value\nc.merge[(t take b),(256 take a)]"}
field3:{"type":"field","size":[85,13],"pos":[150,237],"locked":1,"border":0,"align":"center","value":"threshold"}

{card:texturemappedpractice}
{widgets}
button1:{"type":"button","size":[60,20],"pos":[442,312],"script":"whatisatransition.0","text":"Next","style":"rect"}
button2:{"type":"button","size":[60,20],"pos":[10,312],"script":"whatisatransition.0","text":"Prev","style":"rect"}
title:{"type":"field","size":[492,17],"pos":[10,22],"locked":1,"font":"menu","show":"invert","border":1,"align":"center","value":"Texture-Mapped Transitions (Practice)"}
button3:{"type":"button","size":[60,20],"pos":[78,312],"script":"whatisatransition.0","text":"Index","style":"rect"}
field1:{"type":"field","size":[222,259],"pos":[280,47],"locked":1,"border":0,"value":"Note how we can compute the texture \"i\" at our leisure before our transition function ever runs.\n\nWith more levels in our grayscale texture, the transition will appear smoother, or remain smooth-looking for a longer transition duration.\n\nOne downside to this approach is that the effect has a fixed scale; the vertical stripes in this example will always have the same width, irrespective of the canvas dimensions, making small preview images of the transition misleading.\n\nStill, many complex and useful effects are possible with this technique. PublicTransit uses it for transitions like \"Dissolve\" and \"Melt\"."}
ex1:{"type":"field","size":[259,174],"pos":[10,49],"style":"code","value":"n:8\np:(range n),(rev range n)\ni:image[(count p),1]\ni.pixels:p\n\non Blinds c a b t do\n c.merge[i]\n c.merge[((t*n) take b),(256 take a)]\nend"}
c_mask:{"type":"canvas","size":[85,57],"pos":[34,243],"locked":1,"animated":1,"volatile":1,"script":"compositingtransitions.0","show":"transparent","scale":1}
a:{"type":"canvas","size":[85,57],"pos":[249,264],"locked":1,"show":"none","image":"%%IMG3AFUAOQSwyUmrvTjrzbv/YCiOZGmeaKqubOu+cCzPFmADdH7dt+43PN4vF+wNZUXh8ZVULltN43MVdU5PVeuVlA1uS93idxQFJsehsuSM9qjX7PamWXnLd3EK/Y7Z18R8f4B4XoF1eYeDhn6EhYZmio1SgYx9kXeVkpOYYZ2LnZ6UoGGfo118pqFtqaporKSriB2ZU7Rzsk+2HLo/vBq+RLgfwr3Es8bBjlzINMy7l0POt8q5WsvU1Tgp0o+Wm90i3+Dj5OXm5+jp6mgR"}
b:{"type":"canvas","size":[85,57],"pos":[254,271],"locked":1,"show":"none","image":"%%IMG3AFUAOQQwyUmrvTjrzbv/YCiOZGmeaKqubOu+cCzPdG3fZKDvPA7zQKBvFSwKhzmjsocULZ+6ZggKlYKoT+sHOylqPdmK98sxYszkzfiCTmfWYribHaTL5/GjJIw/1xNVfW91WIVfhYhtSImMekONkFFNkZCTlIyWl4mLiFN3NXwlnzSKJ6OkfymnM6tXrTGlTkqZjrKztDuiS1avFlRavXtcwKm+mGSxlWlol3iawTjPTH3SghTN1nnD2YO/3GU9td9qkuPm5+jp6uszEQ=="}
field3:{"type":"field","size":[85,14],"pos":[34,229],"locked":1,"border":0,"align":"center","value":"mask only"}
c_full:{"type":"canvas","size":[85,57],"pos":[142,243],"locked":1,"volatile":1,"show":"transparent","scale":1}
field2:{"type":"field","size":[85,14],"pos":[142,229],"locked":1,"border":0,"align":"center","value":"with images"}

{card:designprinciples}
{widgets}
button1:{"type":"button","size":[60,20],"pos":[442,312],"script":"whatisatransition.0","text":"Next","style":"rect"}
button2:{"type":"button","size":[60,20],"pos":[10,312],"script":"whatisatransition.0","text":"Prev","style":"rect"}
title:{"type":"field","size":[492,17],"pos":[10,22],"locked":1,"font":"menu","show":"invert","border":1,"align":"center","value":"Design Principles"}
button3:{"type":"button","size":[60,20],"pos":[78,312],"script":"whatisatransition.0","text":"Index","style":"rect"}
field1:{"type":"field","size":[305,259],"pos":[197,47],"locked":1,"border":0,"value":{"text":["Here are a few ideas to keep in mind when designing transition functions. All of these rules can be bent, in the right circumstances, but following them will make your transitions easier to reason about and more reusable.\n\n","Scale Invariance:"," Not all decks are the same size. Don't hardcode card dimensions; always adapt to the size and aspect-ratio of the canvas you're given.\n\n","Timing Invariance:"," Transitions can be run at many speeds. If Decker is running slow, it may choose to drop transition frames. Don't write your transition functions to expect a specific number of frame steps. The tween value will, however, always hit exactly 0 initially and exactly 1 on the final frame.\n\n","Purity:"," Avoid depending on external state in your function; the same inputs should yield the same output. If you need random-looking behavior, prefer pre-shuffled lookup tables to actually calling random[].\n\nRemember that your transition function must complete within a small quota. Keep it as light as possible! You will not have time to compute every pixel of the screen individually; leverage what ","the canvas widget"," and ","the image interface"," can do for you."],"font":["","menu","","menu","","menu","","","","",""],"arg":["","","","","","","","http://beyondloom.com/decker/decker.html#canvasinterface","","http://beyondloom.com/decker/decker.html#imageinterface",""]}}
ex1:{"type":"field","size":[129,101],"pos":[36,111],"locked":1,"style":"code","value":"on BoxIn c a b t do\n c.rect[\n  (c.size/2)\n  (c.size*t)\n  \"center\"\n ]\n c.merge[a b]\nend"}
field12:{"type":"field","size":[119,35],"pos":[40,218],"locked":1,"show":"invert","border":0,"align":"center","value":"the built-in transitions adhere to all of these principles."}

{card:inline functions}
{widgets}
button1:{"type":"button","size":[60,20],"pos":[442,312],"script":"whatisatransition.0","text":"Next","style":"rect"}
button2:{"type":"button","size":[60,20],"pos":[10,312],"script":"whatisatransition.0","text":"Prev","style":"rect"}
title:{"type":"field","size":[492,17],"pos":[10,22],"locked":1,"font":"menu","show":"invert","border":1,"align":"center","value":"Tips & Tricks: Inline Functions"}
button3:{"type":"button","size":[60,20],"pos":[78,312],"script":"whatisatransition.0","text":"Index","style":"rect"}
field1:{"type":"field","size":[180,215],"pos":[322,91],"locked":1,"border":0,"value":"If you're making a fancy transition effect that relates to state in your deck or will only ever be used in one place, you don't necessarily have to install it with transition[].\n\nIt's also perfectly valid to provide an \"inline\" transition function as the second argument to go[]."}
ex1:{"type":"field","size":[271,141],"pos":[32,71],"style":"code","value":"go[\n liminalspace\n on OneOffTransition c a b t do\n  p:c.size/2\n  s:t*max c.size\n  o:t*pi/2\n  d:flip p+s*flip unit o+2*pi*(range 4)/4\n  c.poly[d]\n  c.merge[a b]\n end\n 30\n]"}
demobtn:{"type":"button","size":[79,29],"pos":[125,223],"script":"sequenced.0","show":"invert","text":"Try It!","style":"rect"}

{card:screenshake}
image:"%%"
{widgets}
button2:{"type":"button","size":[60,20],"pos":[10,312],"script":"whatisatransition.0","text":"Prev","style":"rect"}
title:{"type":"field","size":[492,17],"pos":[10,22],"locked":1,"font":"menu","show":"invert","border":1,"align":"center","value":"Tips & Tricks: Screen Shake"}
button3:{"type":"button","size":[60,20],"pos":[442,312],"script":"whatisatransition.0","text":"Index","style":"rect"}
field1:{"type":"field","size":[180,200],"pos":[322,106],"locked":1,"border":0,"value":{"text":["Transitions don't necessarily have to move you between cards. They're handy for any situation where you want to temporarily take over the entire screen to draw some kind of effect.\n\nHere's an example of a simple ","screen-shake"," effect you can drop into nearly any script!"],"font":["","",""],"arg":["","https://gdcvault.com/play/1016487/Juice-It-or-Lose",""]}}
ex1:{"type":"field","size":[271,119],"pos":[32,93],"style":"code","value":"go[\n card\n on ScreenShake c a b t do\n  local m:(30,30)*1-t\n  c.rect[0,0 c.size]\n  c.paste[a (random@2*m)-m]\n end\n 15\n]"}
demobtn:{"type":"button","size":[79,29],"pos":[125,223],"script":"sequenced.0","show":"invert","text":"Try It!","style":"rect"}

