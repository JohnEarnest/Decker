title:{"type":"field","size":[492,17],"pos":[10,22],"locked":1,"font":"menu","show":"invert","border":1,"align":"center","value":"The Built-In Transitions"}
button3:{"type":"button","size":[60,20],"pos":[78,312],"script":"whatisatransition.0","text":"Index","style":"rect"}
field1:{"type":"field","size":[248,224],"pos":[254,78],"locked":1,"border":0,"value":{"text":["Decker always has 10 basic transition effects available:\n\nThe ","slide"," transitions translate the source card over to the destination card, moving up, down, left, or right; these are good for representing movement on a flat plane.\n\nThe ","wipe"," transitions keep the source and destination cards in the same location, but gradually replace one with the other along a straight division; these are good for animated sequences.\n\nThe ","box"," transitions replace the source with the destination along a growing or shrinking centered rectangle; these are good for representing non-local motion in a deck."],"font":["","menu","","menu","","menu",""],"arg":["","","","","","",""]}}
demo:{"type":"canvas","size":[85,57],"pos":[90,69],"locked":1,"animated":1,"volatile":1,"script":"builtintransitions.0","show":"transparent","scale":1}
a:{"type":"canvas","size":[85,57],"pos":[37,218],"locked":1,"show":"none","image":"%%IMG3AFUAOQSwyUmrvTjrzbv/YCiOZGmeaKqubOu+cCzPFmADdH7dt+43PN4vF+wNZUXh8ZVULltN43MVdU5PVeuVlA1uS93idxQFJsehsuSM9qjX7PamWXnLd3EK/Y7Z18R8f4B4XoF1eYeDhn6EhYZmio1SgYx9kXeVkpOYYZ2LnZ6UoGGfo118pqFtqaporKSriB2ZU7Rzsk+2HLo/vBq+RLgfwr3Es8bBjlzINMy7l0POt8q5WsvU1Tgp0o+Wm90i3+Dj5OXm5+jp6mgR"}
b:{"type":"canvas","size":[85,57],"pos":[133,218],"locked":1,"show":"none","image":"%%IMG3AFUAOQQwyUmrvTjrzbv/YCiOZGmeaKqubOu+cCzPdG3fZKDvPA7zQKBvFSwKhzmjsocULZ+6ZggKlYKoT+sHOylqPdmK98sxYszkzfiCTmfWYribHaTL5/GjJIw/1xNVfW91WIVfhYhtSImMekONkFFNkZCTlIyWl4mLiFN3NXwlnzSKJ6OkfymnM6tXrTGlTkqZjrKztDuiS1avFlRavXtcwKm+mGSxlWlol3iawTjPTH3SghTN1nnD2YO/3GU9td9qkuPm5+jp6uszEQ=="}
transitionName:{"type":"grid","size":[100,145],"pos":[82,139],"locked":1,"lines":0,"format":"s","value":{"Transition Name":["SlideRight","SlideLeft","SlideDown","SlideUp","WipeRight","WipeLeft","WipeDown","WipeUp","BoxIn","BoxOut"]},"row":0,"col":0}

{script:builtintransitions.0}
on view do
 d:120
 t:1&(d%sys.frame)/(d/3)-1
 c1:if 2%floor sys.frame/d a else b end
 c2:if 2%floor sys.frame/d b else a end
 me.clear[]
 transition[][first transitionName.rowvalue][me c1.copy[] c2.copy[] t]
end
{end}

{card:applyingtransitions}
image:"%%"
script:"applyingtransitions.0"
{widgets}
button1:{"type":"button","size":[60,20],"pos":[442,312],"script":"whatisatransition.0","text":"Next","style":"rect"}
button2:{"type":"button","size":[60,20],"pos":[10,312],"script":"whatisatransition.0","text":"Prev","style":"rect"}
title:{"type":"field","size":[492,17],"pos":[10,22],"locked":1,"font":"menu","show":"invert","border":1,"align":"center","value":"Using Transitions with \"Action...\""}
button3:{"type":"button","size":[60,20],"pos":[78,312],"script":"whatisatransition.0","text":"Index","style":"rect"}
field1:{"type":"field","size":[248,198],"pos":[254,104],"locked":1,"border":0,"value":{"text":["The simplest way to use transitions doesn't require any scripting: the \"Action...\" button in a button widget's properties modal lets you choose a transition to apply when a button is clicked.\n\nWhen \"With Transition\" is enabled, you'll see a list of available transitions to choose from and a tiny preview of the selected transition.\n\nThe list here will always include the built-in transitions. If you have added a module to your deck which provides more transitions, like the ","PublicTransit"," module included here, you may have many additional options!"],"font":["","",""],"arg":["","gallery",""]}}
field2:{"type":"field","size":[82,15],"pos":[61,117],"locked":1,"font":"menu","border":0,"align":"center","value":"Button Action"}
enable:{"type":"button","size":[88,13],"pos":[102,141],"volatile":1,"script":"applyingtransitions.1","font":"body","show":"transparent","text":"With Transition","style":"check"}
preview:{"type":"canvas","size":[17,13],"pos":[195,140],"locked":1,"animated":1,"volatile":1,"script":"applyingtransitions.2","show":"none","scale":1}
tname:{"type":"grid","size":[109,69],"pos":[103,156],"locked":1,"show":"none","headers":0,"lines":0,"format":"s","value":{"Transition Name":["SlideRight","SlideLeft","SlideDown","SlideUp","WipeRight","WipeLeft","WipeDown","WipeUp","BoxIn","BoxOut"]},"row":0,"col":0}
field3:{"type":"field","size":[58,34],"pos":[22,174],"locked":1,"border":0,"align":"center","value":"enable a transition animation"}

{script:applyingtransitions.0}
on view do
 tname.toggle["solid" enable.value]
 preview.toggle["solid" enable.value]
end
{end}

{script:applyingtransitions.1}
on click do
 view[]
end
{end}

{script:applyingtransitions.2}


on view do
 d:60
 a:image["%%IMG0ABEADQAAAAAAAACAAAFAAAIgAAIgAAQQAAfwAAgIAAgIAAgIAAAAAAAAAA=="]
 b:image["%%IMG0ABEADf//gP//gPA/gPffgPffgPAPgPf3gPf3gPf3gPf3gPAPgP//gP//gA=="]
 t:(d%sys.frame)/d-1
 c1:if 2%floor sys.frame/d a else b end
 c2:if 2%floor sys.frame/d b else a end
 me.clear[]
 transition[][first tname.rowvalue][me c1 c2 t]
end
{end}

{card:scriptingtransition}
{widgets}
button1:{"type":"button","size":[60,20],"pos":[442,312],"script":"whatisatransition.0","text":"Next","style":"rect"}
button2:{"type":"button","size":[60,20],"pos":[10,312],"script":"whatisatransition.0","text":"Prev","style":"rect"}
title:{"type":"field","size":[492,17],"pos":[10,22],"locked":1,"font":"menu","show":"invert","border":1,"align":"center","value":"Using Transitions with \"go[]\""}
button3:{"type":"button","size":[60,20],"pos":[78,312],"script":"whatisatransition.0","text":"Index","style":"rect"}
field1:{"type":"field","size":[248,230],"pos":[254,72],"locked":1,"border":0,"value":"The \"Action...\" dialog is really just a shortcut for writing a simple script for your buttons.\n\nThe go[] function is how you tell Decker to change cards. The first argument to go[] will always be the card you want to visit; either specified as a card value or the card's name, as a string.\n\nThe go[] function can optionally take a transition name (as a string) as its second argument.\n\nThe go[] function can also optionally take a time delay (a number of frames) as its third argument. By default, Decker will make transitions last 30 frames, or half a second. A smaller number here will make the transition faster, and a larger number will make it slower.\n\nTry experimenting a bit with the example to the left!"}
ex1:{"type":"field","size":[234,137],"pos":[10,85],"script":"scriptingtransition.0","style":"code","value":"on click do\n go[liminalspace \"BoxIn\" 15]\nend"}
demobtn:{"type":"button","size":[79,29],"pos":[95,228],"script":"scriptingtransition.1","show":"invert","text":"Try It!","style":"rect"}

{script:scriptingtransition.0}
on change do
 demobtn.script:me.text
end
{end}

{script:scriptingtransition.1}
on click do
 go[liminalspace "BoxIn" 15]
end
{end}

