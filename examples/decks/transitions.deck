button2:{"type":"button","size":[60,20],"pos":[10,312],"script":"whatisatransition.0","text":"Prev","style":"rect"}
title:{"type":"field","size":[492,17],"pos":[10,22],"locked":1,"font":"menu","show":"invert","border":1,"align":"center","value":"Background: Canvas.merge[]"}
button3:{"type":"button","size":[60,20],"pos":[78,312],"script":"whatisatransition.0","text":"Index","style":"rect"}
field1:{"type":"field","size":[212,259],"pos":[290,47],"locked":1,"border":0,"value":{"text":["The ","canvas.merge[]"," function can do a number of handy things, but the most pertinent to making transitions is compositing images together based on a mask.\n\nWhen we call merge[] with one or more images (as separate arguments or as a list), each pixel in the current contents of the canvas will be treated as a number N and be replaced with the corresponding pixel in the Nth input image.\n\nPut another way, if we draw a \"mask\" out of patterns 0 and 1 on a canvas and then merge[] in images A and B, the parts of the mask that were pattern 0 will be taken from image A, and the parts of the image that were pattern 1 will be taken from image B.\n\nSpend a little time staring at this example until it makes sense; we will use canvas.merge[] for nearly every transition function we write. Try scribbling on the \"mask\" canvas, if you like."],"font":["","menu",""],"arg":["","",""]}}
ex1:{"type":"field","size":[240,29],"pos":[30,181],"script":"canvasdrawing.1","scrollbar":0,"style":"code","value":"c.paste[mask.copy[]]\nc.merge[a.copy[] b.copy[]]\n"}
c:{"type":"canvas","size":[85,57],"pos":[103,236],"locked":1,"volatile":1,"show":"transparent","scale":1}
a:{"type":"canvas","size":[85,57],"pos":[103,100],"locked":1,"image":"%%IMG3AFUAOQSwyUmrvTjrzbv/YCiOZGmeaKqubOu+cCzPFmADdH7dt+43PN4vF+wNZUXh8ZVULltN43MVdU5PVeuVlA1uS93idxQFJsehsuSM9qjX7PamWXnLd3EK/Y7Z18R8f4B4XoF1eYeDhn6EhYZmio1SgYx9kXeVkpOYYZ2LnZ6UoGGfo118pqFtqaporKSriB2ZU7Rzsk+2HLo/vBq+RLgfwr3Es8bBjlzINMy7l0POt8q5WsvU1Tgp0o+Wm90i3+Dj5OXm5+jp6mgR"}
b:{"type":"canvas","size":[85,57],"pos":[192,100],"locked":1,"image":"%%IMG3AFUAOQQwyUmrvTjrzbv/YCiOZGmeaKqubOu+cCzPdG3fZKDvPA7zQKBvFSwKhzmjsocULZ+6ZggKlYKoT+sHOylqPdmK98sxYszkzfiCTmfWYribHaTL5/GjJIw/1xNVfW91WIVfhYhtSImMekONkFFNkZCTlIyWl4mLiFN3NXwlnzSKJ6OkfymnM6tXrTGlTkqZjrKztDuiS1avFlRavXtcwKm+mGSxlWlol3iawTjPTH3SghTN1nnD2YO/3GU9td9qkuPm5+jp6uszEQ=="}
