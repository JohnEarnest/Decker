titleshape:{"type":"button","size":[484,107],"pos":[14,79],"script":"Index.4","show":"transparent","style":"invisible","value":0}

{script:Index.0}
on view do
 bullet:image["%%IMG0AAYADQAAAAB49Pz8/HgAAAA="]
 i:select c:key t:value..widgets.title.text where value..widgets.title from deck.cards
 index.value:raze each row in rows i
  rtext.make["" "" bullet],
  rtext.make["  "],
  rtext.make[("%s\n" format row.t) "mono" row.c]
 end
end
{end}

{script:Index.1}
on link val do
 go[val "BoxIn" 15]
end
{end}

{script:Index.2}
on click do
  go["Next" "SlideLeft" 15]
end
{end}

{script:Index.3}
on click do
 go[gallery "BoxIn" 15]
end
{end}

{script:Index.4}
on click do
 t:card.image.copy[me.pos me.size]
 if me.value
  t.map[(0,1) dict (0,0) 1]
 else
  t.map[(0,1) dict (0,39)]
  p1:0,me.size[1]*1/5
  p2:0,me.size[1]*2/5
  t.paste[t.copy[p1 me.size*1,3/5].map[0 dict 0 36] p1]
  t.paste[t.copy[p2 me.size*1,1/5].map[0 dict 0 32] p2]
  t.outline[1].outline[1]
 end
 me.value:!me.value
 a:card.image.copy[]
 b:card.image.copy[].paste[t me.pos]
 c:card.add["canvas"]
 c.show:"none"
 c.size:card.size
 f:transition[].HeartIn
 duration:20
 each time in range duration
  c.clear[]
  f[c a b time/duration-1]
  card.image.paste[c.copy[]]
  sleep[]
 end
 card.remove[c]
end
{end}

{card:whatisatransition}
