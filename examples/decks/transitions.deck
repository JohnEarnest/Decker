field1:{"type":"field","size":[222,67],"pos":[144,90],"locked":1,"border":0,"align":"center","value":{"text":["So far we've focused on using existing transitions and very simple scripting.\n\nIn the following sections we'll dive into writing new transitions from scratch. This will involve a bit of ","fancier"," scripting..."],"font":["","menu",""],"arg":["","",""]}}
field2:{"type":"field","size":[120,26],"pos":[199,220],"locked":1,"border":0,"align":"center","value":"If that's not your thing, why not skip ahead to the"}
