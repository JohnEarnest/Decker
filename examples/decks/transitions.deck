preview:{"type":"canvas","size":[170,114],"pos":[332,51],"image":"%%","scale":1}
field1:{"type":"field","size":[237,25],"pos":[265,307],"show":"invert","style":"plain","align":"center","value":"import the \"PublicTransit\" module from this deck in order to use these transitions in your own projects!"}
button3:{"type":"button","size":[60,20],"pos":[10,312],"script":"whatisatransition.0","text":"Index","style":"rect"}
title:{"type":"field","size":[492,17],"pos":[10,22],"locked":1,"font":"menu","show":"invert","border":1,"align":"center","value":"Transition Gallery"}

{script:gallery.0}

on scaledback c do
 preview.paste[c.image 0,0,preview.size]
 preview.copy[]
end

on example do
 t:transition[][options.rowvalue.value]
 sa:scaledback[gallery]
 sb:scaledback[Darkmode]
 preview.paste[sa 0,0,sa.size]
 each i in range 30
  preview.clear[]
  t[preview sa sb i/30]
  sleep[]
 end
 preview.paste[sb 0,0,sb.size]
end

on view do
 options.value:table keys PublicTransit.descs
 descript.text:PublicTransit.descs[options.rowvalue.value]
 version.text:"v%0.1f" format deck.modules.PublicTransit.version
end
{end}

{script:gallery.1}
on click row do
 view[]
 example[]
end
{end}

{script:gallery.2}
on click do
 example[]
end
{end}

{script:gallery.3}
on click do
 t:options.rowvalue.value
 go[Darkmode t]
 sleep[60]
 go["Back" t]
end
{end}

