{card:card1}
{widgets}
button1:{"type":"button","size":[60,20],"pos":[442,312],"script":"whatisatransition.0","text":"Next","style":"rect"}
button2:{"type":"button","size":[60,20],"pos":[10,312],"script":"whatisatransition.0","text":"Prev","style":"rect"}
title:{"type":"field","size":[492,17],"pos":[10,22],"locked":1,"font":"menu","show":"invert","border":1,"align":"center","value":"Finding More Transitions"}
button3:{"type":"button","size":[60,20],"pos":[78,312],"script":"whatisatransition.0","text":"Index","style":"rect"}
field1:{"type":"field","size":[240,259],"pos":[262,47],"locked":1,"border":0,"value":{"text":["Looking for more transition modules to use in your projects? In addition to the PublicTransit module, Decker users have created several libraries you might want to check out:\n\n","Screen Melting Transitions"," by Screwtapello are designed to mimic Doom's level transition animations. Be sure to open the .deck in a text editor and read through the source code!\n\n","Wacky Wipes"," by Millie Squilly offers a handful of silly wipe effects with hand-drawn decorations. These could also be a good starting point for making your own variants.\n\nThe ","Utena"," module by Internet Janitor (that's me) is internally based on transitions and offers scriptable title effects based on the titular anime series."],"font":["","","","","","",""],"arg":["","https://screwtapello.itch.io/screen-melt-transitions","","https://micpp.itch.io/wackywipes","","http://beyondloom.com/decker/goofs/utena.html",""]}}
ref:{"type":"canvas","size":[148,138],"pos":[10,159],"locked":1,"show":"none","border":0,"image":"%%","scale":1}
rose1:{"type":"canvas","size":[148,138],"pos":[21,55],"locked":1,"script":"card1.0","show":"transparent","border":0,"image":"%%","scale":1}
r1:{"type":"field","size":[23,18],"pos":[175,313],"volatile":1,"show":"none"}
r2:{"type":"field","size":[23,18],"pos":[206,313],"volatile":1,"show":"none"}
rose2:{"type":"canvas","size":[88,82],"pos":[128,178],"locked":1,"script":"card1.1","show":"transparent","border":0,"image":"%%","scale":1}

{script:card1.0}
on click pos do
 me.animated:!me.animated
end

on view do
 a:r1.data:r1.data+0.02
 me.clear[]
 me.paste[ref.copy[].rotate[a]]
end
{end}

{script:card1.1}
on click pos do
 me.animated:!me.animated
end

on view do
 a:r2.data:r2.data-0.008
 me.clear[]
 me.paste[ref.copy[].scale[me.size 1].rotate[a]]
end
{end}

