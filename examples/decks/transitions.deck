a:{"type":"canvas","size":[85,57],"pos":[37,218],"locked":1,"show":"none","image":"%%IMG3AFUAOQSwyUmrvTjrzbv/YCiOZGmeaKqubOu+cCzPFmADdH7dt+43PN4vF+wNZUXh8ZVULltN43MVdU5PVeuVlA1uS93idxQFJsehsuSM9qjX7PamWXnLd3EK/Y7Z18R8f4B4XoF1eYeDhn6EhYZmio1SgYx9kXeVkpOYYZ2LnZ6UoGGfo118pqFtqaporKSriB2ZU7Rzsk+2HLo/vBq+RLgfwr3Es8bBjlzINMy7l0POt8q5WsvU1Tgp0o+Wm90i3+Dj5OXm5+jp6mgR"}
