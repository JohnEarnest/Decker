{contraption:scrollcanvas}
size:[100,100]
resizable:1
margin:[2,2,18,18]
description:"A scrollable, resizable viewport into an arbitrary-size inner canvas."
script:"scrollcanvas.0p"
template:"on click pos do\n \nend\n\non drag pos do\n \nend\n\non release pos do\n \nend\n"
{widgets}
display:{"type":"canvas","size":[85,85],"pos":[0,0],"locked":1,"volatile":1,"scale":1}
h:{"type":"slider","size":[85,16],"pos":[0,84],"interval":[0,100]}
v:{"type":"slider","size":[16,85],"pos":[84,0],"interval":[0,100],"style":"vert"}
c:{"type":"canvas","size":[26,27],"pos":[144,-12],"show":"none","scale":1}

{script:scrollcanvas.0p}
on get_canvas   do c end
on get_refresh  do view end
on get_scroll   do h.value,v.value end
on set_scroll x do h.value:x[0] v.value:x[1] view[] end
on change       do view[] end
on click      x do card.event["click"   x+get_scroll[]] end
on drag       x do card.event["drag"    x+get_scroll[]] end
on release    x do card.event["release" x+get_scroll[]] end

on view do
 c.show:"none"
 c.volatile:card.volatile
 h.interval:0,0|c.size[0]-display.size[0]
 v.interval:0,0|c.size[1]-display.size[1]
 h.locked:h.interval~0,0
 v.locked:v.interval~0,0
 display.show:card.show
 display.pattern:13
 display.rect[0,0 display.size]
 display.paste[c.copy[get_scroll[] display.size] 0,0 1]
end
{end}

{contraption:imageEnum}
size:[100,100]
resizable:1
margin:[17,3,18,5]
description:"select from among enumerated image values."
version:1.1
script:"imageEnum.0p"
template:"on change img index do\n \nend"
attributes:{"name":["options"],"label":["Options"],"type":["rich"]}
{widgets}
s:{"type":"slider","size":[100,100],"pos":[0,0],"interval":[0,0],"format":"","style":"compact"}
c:{"type":"canvas","size":[70,96],"pos":[15,2],"locked":1,"border":0,"scale":1}
o:{"type":"field","size":[44,53],"pos":[129,-20],"locked":1,"show":"none"}

{script:imageEnum.0p}
on get_options do o.value end
on set_options x do o.value:x view[] x end
on get_value do o.images[s.value] end
on get_valueIndex do s.value end
on set_valueIndex x do s.value:x view[] x end

on view do
 im:o.images
 i:im[s.value]
 s.interval:0,0|(count im)-1
 s.locked:card.locked
 s.show  :card.show
 c.show  :card.show
 c.clear[]
 c.paste[i .5*c.size-i.size 1]
end

on change do
 card.event["change" get_value[] s.value]
 view[]
end
{end}

