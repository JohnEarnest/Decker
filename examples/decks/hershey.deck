field1:{"type":"field","size":[248,203],"pos":[254,83],"locked":1,"border":0,"value":"Dr. Allen Vincent Hershey developed some of the first digital typefaces, described by simple sequences of straight line segments. These were originally published in his 1967 report \"Calligraphy for Computers\".\n\nThese typefaces still have many useful applications today for rendering smoothly scalable text or driving plotters on resource-constrained systems. They are frequently distributed in the .jhf \"Hershey\" file format.\n\nThis deck includes a module named \"hershey\" for manipulating .jhf files, manipulating vector glyphs, and drawing vectorized text to Decker canvases. For your convenience, it also includes a number of additional modules which each contain a directly usable pre-decoded Hershey font.\n\n"}
target:{"type":"canvas","size":[188,148],"pos":[39,90],"locked":1,"volatile":1,"scale":1}
scale:{"type":"slider","size":[142,25],"pos":[62,248],"script":"background.2","interval":[1,5],"value":2.4,"step":0.1}

{script:background.0}
on view do
 target.clear[]
 f:hershey.scale[hf_times scale.value]
 hershey.textc[target f "Aa" 0,0 target.size]
end
{end}

{script:background.1}
on click do
 t.Prev:"SlideRight"
 t.Next:"SlideLeft"
 t.Index:"BoxOut"
 go[me.text t[me.text] 15]
end
{end}

{script:background.2}
on change do
 view[]
end
{end}

