field3:{"type":"field","size":[256,17],"pos":[10,44],"locked":1,"font":"menu","border":0,"align":"center","value":".jhf"}
output:{"type":"field","size":[256,141],"pos":[10,147],"volatile":1,"scrollbar":1,"style":"code"}
