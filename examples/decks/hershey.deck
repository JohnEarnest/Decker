{script:fontmodules.0}
on redraw do
 local f:deck.modules[first fontlist.rowvalue].value
 local c:preview.canvas
 local margin:10
 local alpha:"\n" fuse 16 window "%a" format list 32+range 95

 f:hershey.scale[f scale.value]
 c.brush:brush.valueIndex
 c.size:(margin*2)+hershey.textsize[f alpha]
 c.clear[]
 c.pattern:32
 c.rect[0,0 c.size]
 c.pattern:1
 hershey.text[c f alpha margin]
 preview.refresh[]
end

on view do
 fontlist.value:select where value..data.is_hershey_font from deck.modules
 if fontlist.row~-1 fontlist.row:0 end
 redraw[]
end
{end}

{script:fontmodules.1}
on click do
 redraw[]
end
{end}

{script:fontmodules.2}
on change do
 redraw[]
end
{end}

