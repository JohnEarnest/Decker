{module:hershey}
description:"Read, write, render and manipulate Hershey vector fonts."
version:0.2
{script}
# see https://en.wikipedia.org/wiki/Hershey_fonts

COLUMNS:"%[id]5i%[n]3i%[left]1s%[right]1s%[points]s"
MISSING:("left","right","strokes")dict 0,0,list ()

on hershey_parse text do
 on pos x do ("%a" parse x)-82 end
 local glyphs:each line in COLUMNS parse "" drop "\n" split text
  local g:()
  g.id     :line.id
  g.left   :-first pos[line.left ]
  g.right  : first pos[line.right]
  g.strokes:each stroke in " R" split line.points
   pos@2 window stroke
  end
  if g.strokes~list () g.strokes:() end
  g
 end
 local r:()
 local p:raze raze range glyphs..strokes
 r.lineheight:last(max p)-min p
 r.glyphs:glyphs..id dict each v in glyphs "id" drop v end
end

on hershey_format font do
 on pos x do "%a" format x+82 end
 "\n" fuse range each glyph key in font.glyphs
  local t:()
  t.id    :key
  t.left  :pos[floor -glyph.left ]
  t.right :pos[floor  glyph.right]
  t.n     :(count raze glyph.strokes)+(count glyph.strokes)
  t.points:" R" fuse each stroke in glyph.strokes
   pos@floor raze stroke
  end
  COLUMNS format t
 end
end

on hershey_scale font scale do
 r.lineheight:font.lineheight*last scale
 r.glyphs:each glyph in font.glyphs
  glyph.left   :glyph.left   *first scale
  glyph.right  :glyph.right  *first scale
  glyph.strokes:glyph.strokes*list list scale
 end
end

on linepath font text do
 local x:0
 r.path:raze each char in "%a" parse text
  local glyph:MISSING unless font.glyphs[char]
  x:x+glyph.left
  t:glyph.strokes+list list x,0
  x:x+glyph.right
  t
 end
 r.wid:x
end

on hershey_textsize font text do
 local lines:"\n" split text
 local w:max each line in lines linepath[font line].wid end
 w,font.lineheight*count lines
end

on pathtranslate pos path do
 path+list list pos
end

on hershey_textpath font text do
 raze each line i in "\n" split text
  pathtranslate[(0,font.lineheight*i+.5) linepath[font line].path]
 end
end

on hershey_textpathc font text size do
 local lines:"\n" split text
 local l:raze each line i in lines
  local p:linepath[font line]
  pathtranslate[((.5*size[0]-p.wid),(font.lineheight*i)) p.path]
 end
 pathtranslate[0,.5*size[1]-(font.lineheight*-1+count lines) l]
end

on hershey_text canvas font text pos do
 canvas.line @ pathtranslate[pos hershey_textpath[font text]]
end

on hershey_textc canvas font text pos size do
 canvas.line @ pathtranslate[pos hershey_textpathc[font text size]]
end

module.parse    :hershey_parse
module.format   :hershey_format
module.scale    :hershey_scale
module.textpath :hershey_textpath
module.textpathc:hershey_textpathc
module.text     :hershey_text
module.textc    :hershey_textc
module.textsize :hershey_textsize
{end}

{module:hf_futura}
description:"Futura vector font, for use with the 'hershey' module. Originally created by Dr. A. V. Hershey while working at the US National Bureau of Standards."
