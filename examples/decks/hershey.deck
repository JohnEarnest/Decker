field1:{"type":"field","size":[209,106],"pos":[293,48],"locked":1,"border":0,"value":"Uniformly scaling a path is simple: just multiply it by a scalar number.\n\nTo scale by a non-uniform factor, use the same approach as translation, but multiply instead of adding."}
ex1:{"type":"field","size":[276,254],"pos":[10,48],"border":1,"scrollbar":1,"style":"code","value":"p:hershey.textpath[hf_futura \"Text\"]\nc.clear[]\n\n\n# uniform\nc.pattern:colors.red\nc.line @ p*2.5\n\n# non-uniform\nc.pattern:colors.blue\nc.line @ p*list list 3,1"}
