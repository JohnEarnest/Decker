button3:{"type":"button","size":[60,20],"pos":[78,312],"script":"background.1","text":"Index","style":"rect"}
field1:{"type":"field","size":[209,106],"pos":[293,48],"locked":1,"border":0,"value":"Given a path- a list of lists of (x,y) points- the simplest thing you're likely to want to do before drawing it is to translate it in space. Doing this efficiently leverages Lil's secret APL-flavored heritage.\n\nExplicit loops are slow and verbose. Implicit \"conforming\" is better. Transposing data with \"flip\" is faster than an \"each\" loop, but it's best to avoid it if we can."}
ex1:{"type":"field","size":[276,254],"pos":[10,48],"border":1,"scrollbar":1,"style":"code","value":"p:hershey.textpath[hf_futura \"Text\"]\nc.clear[]\n\n# the obvious (slow) way:\nc.brush:0\neach line in p\n c.line[each point in line\n  (5,10) + point\n end]\nend\n\n\n# the better (faster) way:\nc.brush:1\neach line in p\n c.line[flip (70,30)+flip line]\nend\n\n\n# the best (fastest) way:\nc.brush:2\nc.line @ p+list list 140,50"}
button4:{"type":"button","size":[60,20],"pos":[293,282],"script":"hershey_text.0","text":"Try It!"}
c:{"type":"canvas","size":[209,91],"pos":[293,183],"locked":1,"volatile":1,"brush":2,"scale":1}
field5:{"type":"field","size":[209,14],"pos":[293,167],"locked":1,"border":0,"style":"plain","align":"center","value":"c"}

