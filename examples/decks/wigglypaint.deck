{script:main.0}
on backup do
 history.images:target.frames..copy[]
end

on setframes x do
 if count x
  target.size:x[0].size
  target.pos:dims.pos+.5*dims.size-target.size
  each frame i in target.frames
   frame.size:x[i].size
   frame.paste[x[i]]
  end
 end
end

on mask x do
 hi32.toggle["transparent" x]
 target.show:if x "transparent" else "solid" end
 crop.widgets.preview.show:target.show
end

on mirror vh do
 target.mirrormode:vh
end

on changetool w x do
 others:w drop extract value where value..def.name like "pop*" from card.widgets
 others..value:1
 if !w.value play["pick"] end
 w.value:0
 target.brush:x
 if x~"eraser"
  sizeLabel.text:"eraser size"
  markerSizes.valueIndex:toolProps.data.eraser
 else
  sizeLabel.text:"marker size"
  markerSizes.valueIndex:toolProps.data.marker
 end
end
{end}

{script:main.1}
on click do
 changetool[me me.name]
end
{end}

{script:main.2}
on begin do
 backup[]
end
{end}

{script:main.3}
on oval pos size do
 flip pos+size*flip unit 2*pi*(range 20)/20
end

on shake obj tick do
  local st: 10 # time
  local sm: 15 # magnitude
  local sf:0.5 # fade
  local so:obj.pos
  while sm>0
    st:st-1
    obj.pos:so+random[sm,-sm 2]
    if st<0 sm:sm-sf end
    tick[]
  end
  obj.pos:so
end

on click do
 backup[]
 play["boom"]
 t:target.canv
 local s:()
 shake[target on tick do
  t.pattern:0
  each v in s t.poly[v] end
  s:each _ in range 5
   oval[random[max target.size 2] 10+random[30]]
  end
  t.pattern:1
  each v in s t.poly[v] end
  sleep[] 
 end]
 t.pattern:1
 target.pos:dims.pos
 target.size:dims.size
 each f in target.frames f.map[() 0] end
end
{end}

{script:main.4}
on click do
 play["snap"]
 t:if options.widgets.mask.value () else 0 dict 32 end
 gif.frames:target.frames..copy[].map[t]
 gif.delays:3 take 10
 write[gif]
end
{end}

{script:main.5}
on click do
 play["snap"]
 alter.event.init
 go[alter "BoxIn" 15]
end
{end}

{script:main.6}
on click do
 play["erase2"]
 h:history.images
 backup[]
 setframes[h]
end
{end}

{script:main.7}
on click do
 play["snap"]
 go["options" "BoxIn" 15]
end
{end}

{script:main.8}
on change img index do
 play["click"]
 p:toolProps.data
 if sizeLabel.text~"marker size"
  target.hishape:img.encoded
  p.marker:index
 else
  target.ershape:img.encoded
  p.eraser:index
 end
 toolProps.data:p
end
{end}

{script:main.9}
on click do
 play[("boingoff","boingon")[me.value]]
 mirror[(mvert.value,mhoriz.value)]
end
{end}

{card:alter}
image:"%%"
script:"alter.0"
{widgets}
dims:{"type":"button","size":[355,261],"pos":[5,22],"show":"none"}
preview:{"type":"canvas","size":[355,261],"pos":[5,22],"locked":1,"pattern":255,"border":1,"image":"%%","scale":1}
left:{"type":"slider","size":[59,25],"pos":[370,70],"script":"alter.1","interval":[0,355],"style":"compact"}
right:{"type":"slider","size":[59,25],"pos":[370,130],"script":"alter.1","interval":[0,355],"style":"compact"}
bottom:{"type":"slider","size":[59,25],"pos":[370,100],"script":"alter.1","interval":[0,261],"style":"compact"}
top:{"type":"slider","size":[59,25],"pos":[370,40],"script":"alter.1","interval":[0,261],"style":"compact"}
shiftup:{"type":"button","size":[61,26],"pos":[445,39],"script":"alter.2","show":"transparent"}
shiftleft:{"type":"button","size":[61,26],"pos":[445,69],"script":"alter.3","show":"transparent"}
