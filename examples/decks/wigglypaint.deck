{script:options.0}
on view do
 f:"%06H"
 background.text:f format patterns[32]
 foreground.text:f format patterns[47]
 pink      .text:f format patterns[36]
 cyan      .text:f format patterns[39]
 yellow    .text:f format patterns[33]
end

on apply_pal do
 f:"%06H"
 patterns[32]:f parse background.text
 patterns[47]:f parse foreground.text
 patterns[36]:f parse pink      .text
 patterns[39]:f parse cyan      .text
 patterns[33]:f parse yellow    .text
end
{end}

{script:options.1}
on click do
 main.event["mask" me.value]
end
{end}

{script:options.2}
on change do
 apply_pal[]
end
{end}

{script:options.3}
on click do
 colorpicker.event["init" (0+1 drop me.name)]
end
{end}

{script:options.4}
on click row do
 p:"|"split me.rowvalue.palette
 if 5~count p
  background.text:p[0]
  foreground.text:p[1]
  pink      .text:p[2]
  cyan      .text:p[3]
  yellow    .text:p[4]
  apply_pal[]
 end
end
{end}

{script:options.5}
on view do
 fr:main.widgets.target.frames
 fi:(count fr)%sys.frame/5
 me.paste[fr[fi].copy[] 0,0,me.size]
end
{end}

{card:colorpicker}
image:"%%"
script:"colorpicker.0"
{widgets}
colorR:{"type":"slider","size":[225,25],"pos":[144,140],"script":"colorpicker.1","interval":[0,255],"value":199}
colorG:{"type":"slider","size":[225,25],"pos":[144,178],"script":"colorpicker.1","interval":[0,255],"value":1}
colorB:{"type":"slider","size":[225,25],"pos":[144,215],"script":"colorpicker.1","interval":[0,255],"value":243}
colorIndex:{"type":"field","size":[28,21],"pos":[16,33],"locked":1,"show":"none","value":"36"}
cancel:{"type":"button","size":[133,37],"pos":[118,255],"script":"colorpicker.2","text":"Never mind, I dislike this."}
ok:{"type":"button","size":[119,37],"pos":[270,255],"script":"colorpicker.3","text":"Sure!"}

{script:colorpicker.0}
PREVIEW:44

on init i do
 colorIndex.data:i
 cancel.text:random[
  "Oh no, this wasn't what I wanted!",
  "This isn't what I had in mind at all...",
  "Never mind, I dislike this."
 ]
 ok.text:random[
  "That'll do.",
  "Sure!",
  "Make it so!",
  "I can dig it."
 ]
 patterns[PREVIEW]:patterns[i]
 colorR.value:256%patterns[i]/2^16
 colorG.value:256%patterns[i]/2^ 8
 colorB.value:256%patterns[i]
 go[card "StarSpinIn" 15]
end

on view do
 patterns[PREVIEW]:sum(2^16,8,0)*(colorR,colorG,colorB)..value
end
{end}

{script:colorpicker.1}
on change do
 view[]
end
{end}

{script:colorpicker.2}
on click do
 play.cancel
 go["Back" "StarSpinOut" 15]
end
{end}

{script:colorpicker.3}
on click do
 patterns[colorIndex.data]:patterns[PREVIEW]
 play.pick
 go["Back" "StarSpinOut" 15]
end
{end}

{module:pens}
description:"custom brushes for WigglyPaint"
{script}
# 16 round brush images ranging from 1px to 13px:
b:image@"\n"split 1 drop "
%%IMG0AA0ADQ+AP+B/8H/w//j/+P/4//j/+H/wf/A/4A+A
%%IMG0AAwADB+AP8B/4P/w//D/8P/w//D/8H/gP8AfgA==
%%IMG0AAsACx8AP4B/wP/g/+D/4P/g/+B/wD+AHwA=
%%IMG0AAoACh4Af4B/gP/A/8D/wP/Af4B/gB4A
%%IMG0AAkACT4AfwD/gP+A/4D/gP+AfwA+AA==
%%IMG0AAgACDx+/////348
%%IMG0AAcAB3z+/v7+/nw=
%%IMG0AAcABzh8/v7+fDg=
%%IMG0AAYABnj8/Pz8eA==
%%IMG0AAYABjB4/Px4MA==
%%IMG0AAUABXD4+Phw
%%IMG0AAQABGDw8GA=
%%IMG0AAMAA+Dg4A==
%%IMG0AAMAA0DgQA==
%%IMG0AAIAAsDA
%%IMG0AAEAAYA="
brush[on Blobby delta do b[ 5+9&.5*mag delta]end]

# 4x4 stipples:
t:image@"\n"split 1 drop"
%%IMG0AAQABAAwMAA=
%%IMG0AAQABMDAAAA=
%%IMG0AAQABAAAYGA=
%%IMG0AAQABADAwAA=
%%IMG0AAQABIAAAIA=
%%IMG0AAQABAAgAEA=
%%IMG0AAQABEAAEAA=
%%IMG0AAQABAAAgBA="
brush[on StippleTiny do random[t] end]

brush["Eraser" image[11,11].map[() 1]]

# 16x16 stipples: very soft
# this uses a table of pre-permuted combinations of 4 pixels which, together, fill a 16x16 circle:
sl:each t in data:"%j" parse "[
  [[ 5, 1],[ 4,10],[ 9,10],[10, 1]],[[12, 2],[ 8,13],[ 7,14],[ 4,13]],[[ 4, 9],[ 7,10],[12, 9],[14, 4]],[[ 4, 3],[ 9, 2],[ 9, 8],[ 6, 8]],
  [[13, 9],[ 7, 9],[13, 5],[11, 9]],[[10,12],[ 8, 3],[11, 7],[ 3, 7]],[[ 1, 9],[ 6, 2],[ 4,12],[ 3, 6]],[[ 5,14],[ 8,14],[11,12],[15, 5]],
  [[ 1, 3],[11, 1],[ 3, 4],[ 2, 5]],[[ 3,11],[ 5, 4],[10, 3],[ 0, 8]],[[14, 9],[11, 5],[10, 8],[ 8, 4]],[[11, 2],[10, 0],[ 2,10],[11,14]],
  [[ 5, 7],[14, 5],[ 0, 9],[ 4, 2]],[[ 1, 7],[13, 4],[ 2, 3],[13, 3]],[[ 3,14],[ 3,10],[ 7, 4],[12, 8]],[[ 6, 0],[ 3, 9],[ 1, 8],[12, 7]],
  [[ 4,14],[14,10],[ 5, 0],[ 9, 3]],[[14, 3],[ 3,12],[11, 3],[ 9, 1]],[[ 3, 3],[13, 6],[ 2,12],[ 7, 6]],[[ 3, 2],[11, 8],[ 4, 8],[ 8, 0]],
  [[ 7, 2],[ 2, 4],[ 8,11],[12,10]],[[ 8, 1],[ 9, 7],[ 8,12],[13, 7]],[[15, 7],[13, 8],[10,11],[ 2, 2]],[[ 6, 1],[ 8, 6],[ 8, 7],[ 0, 6]],
  [[ 4, 4],[10, 2],[ 4, 1],[ 4, 5]],[[ 5, 2],[ 6,10],[14, 6],[ 9, 4]],[[ 5, 5],[10, 6],[ 5, 3],[ 7,13]],[[12,13],[ 3, 1],[14, 8],[ 5,12]],
  [[ 5,15],[ 8,15],[11, 6],[12,11]],[[ 3, 8],[12,14],[ 6, 9],[ 6, 5]],[[ 0, 7],[ 3, 5],[ 7,11],[ 1, 6]],[[ 6, 7],[ 4, 6],[12, 6],[ 2,11]],
  [[13, 2],[ 6, 3],[10, 9],[10, 4]],[[ 6,15],[ 8, 9],[13,10],[ 8, 8]],[[ 8, 5],[10, 5],[ 5,11],[15, 6]],[[ 4, 7],[ 0,10],[ 8, 2],[10,13]],
  [[11, 4],[13,11],[14,11],[ 5,10]],[[12, 1],[ 7, 7],[14, 7],[14,12]],[[ 6,11],[ 5, 9],[ 3,13],[ 9,13]],[[ 7, 8],[10,10],[ 7, 3],[ 7,15]],
  [[ 9,11],[ 6, 6],[ 4,11],[ 2,13]],[[ 7,12],[11,11],[ 9,14],[ 7, 1]],[[15,10],[ 2, 8],[ 1, 5],[ 9, 0]],[[15, 8],[10,14],[10, 7],[ 9,12]],
  [[ 1,10],[ 9, 5],[15, 9],[ 1,11]],[[ 0, 5],[ 6,14],[ 1, 4],[ 7, 5]],[[ 1,12],[ 9,15],[10,15],[ 5, 8]],[[ 5, 6],[12,12],[11,10],[12, 3]],
  [[ 9, 6],[ 6,12],[ 7, 0],[12, 5]],[[11,13],[ 8,10],[ 2, 7],[ 6,13]],[[13,13],[ 9, 9],[ 2, 9],[12, 4]],[[ 5,13],[13,12],[ 2, 6],[ 6, 4]]
 ]"
 i:image[16,16] each v in t i[v]:1 end i
end
brush[on SoftLrg do random[sl] end]
{end}

{module:PublicTransit}
description:"Fancy transition animations"
version:1.3
{data}
dissolveLut:%%
noiseLut:%%
blindsVertLut:%%IMG3AEAAAQgAASCAgAEEChg4gCCBggUMGjh4ACGChAkUKli4gCGDhg0cOnj48MFDBw4bNGTAcMFCBQoTJESA8MBBAwYLFCRAcMBAAQIDBAQAAgI=
blindsHorizLut:%%IMG3AAEAMAgAASioAEJFDSBKqoBRUweQokqgVNUCpqwaOHX17K0DZ20ZMFurQFlaBMjOGjBWlgCxsQKEhQUAAgI=
{script}
dissolveLut:data.dissolveLut
noiseLut:data.noiseLut
blindsVertLut:data.blindsVertLut
blindsHorizLut:data.blindsHorizLut

on lookup c a b t lut do
 c.merge[lut]
 c.merge[((floor 255*t) take b),(256 take a)]
end

on oval pos size do
 flip pos+size*flip unit 2*pi*(range 20)/20
end

on star c t rot do
 o:c.size/2
 r:(2.5*t)*o
 i:unit(pi/2)+(pi*rot/2)+(range 10)*(pi/5)
 p:each v index in i
  o+(if 2%index 1 else 0.5 end*r)*v
 end
 c.poly[p]
end

on heart c t do
 o:(0.5,0.6)*c.size
 r:t*c.size
 p:each v in (1,0,-1,0)join(0,-1,0,1) o+r*v end
 c.poly[p]
 c.poly[oval[o+r*( 1,-1)/2 r/sqrt 2]]
 c.poly[oval[o+r*(-1,-1)/2 r/sqrt 2]]
end

clickpos:0,0
on circleClick c t do c.poly[oval[clickpos t*max c.size]] end
on circle      c t do c.poly[oval[c.size/2 t*max c.size]] end

on clock c t do
 pos:c.size/2
 size:max c.size
 c.poly[flip pos+size*flip (list 0,0),unit 2*pi*-.25+(range 20*t)/20]
end

ba:bb:nil
on BarnHoriz c a b fst t do
 if fst
  ba:a.copy[        0,0 a.size/2,1]
  bb:a.copy[a.size*.5,0 a.size/2,1]
 end
 c.paste[b]
 c.paste[ba              t*a.size/-2,0]
 c.paste[bb (a.size/2,0)+t*a.size/ 2,0]
end
on BarnVert c a b fst t do
 if fst
  ba:a.copy[       0, 0 a.size/1,2]
  bb:a.copy[a.size*0,.5 a.size/1,2]
 end
 c.paste[b]
 c.paste[ba              t*a.size/0,-2]
 c.paste[bb (a.size/0,2)+t*a.size/0, 2]
end

transition[on Dissolve       c a b t do lookup[c a b t dissolveLut   ] end]
transition[on Melt           c a b t do lookup[c a b t noiseLut      ] end]
transition[on BlindsVert     c a b t do lookup[c a b t blindsVertLut ] end]
transition[on BlindsHoriz    c a b t do lookup[c a b t blindsHorizLut] end]
transition[on StarIn         c a b t do star  [c   t 0] c.merge[a b] end]
transition[on StarOut        c a b t do star  [c 1-t 0] c.merge[b a] end]
transition[on StarSpinIn     c a b t do star  [c   t t] c.merge[a b] end]
transition[on StarSpinOut    c a b t do star  [c 1-t t] c.merge[b a] end]
transition[on HeartIn        c a b t do heart [c   t  ] c.merge[a b] end]
transition[on HeartOut       c a b t do heart [c 1-t  ] c.merge[b a] end]
transition[on ClockIn        c a b t do clock [c   t  ] c.merge[a b] end]
transition[on ClockOut       c a b t do clock [c 1-t  ] c.merge[b a] end]
transition[on CircleIn       c a b t do circle[c   t  ] c.merge[a b] end]
transition[on CircleOut      c a b t do circle[c 1-t  ] c.merge[b a] end]
transition[on CircleInClick  c a b t do if 0~t clickpos:pointer.start end circleClick[c   t] c.merge[a b] end]
transition[on CircleOutClick c a b t do if 0~t clickpos:pointer.start end circleClick[c 1-t] c.merge[b a] end]
transition[on StretchDown    c a b t do c.paste[a] c.paste[b (       0    ,  0),      b.size*1,t] end]
transition[on StretchUp      c a b t do c.paste[a] c.paste[b (c.size*0    ,1-t),(0,1)+b.size*1,t] end]
transition[on StretchRight   c a b t do c.paste[a] c.paste[b (       0    ,  0),      b.size*t,1] end]
transition[on StretchLeft    c a b t do c.paste[a] c.paste[b (c.size*(1-t),  0),(1,0)+b.size*t,1] end]
transition[on RotateDown     c a b t do c.paste[a (c.size*0,t),c.size*   1,1-t ] c.paste[b (       0    ,  0),      c.size*1,t] end]
transition[on RotateUp       c a b t do c.paste[a (       0,0),c.size*   1,1-t ] c.paste[b (c.size*0    ,1-t),(0,1)+c.size*1,t] end]
transition[on RotateRight    c a b t do c.paste[a (c.size*t,0),c.size*(1-t),1  ] c.paste[b (       0    ,  0),      c.size*t,1] end]
transition[on RotateLeft     c a b t do c.paste[a (       0,0),c.size*(1-t),1  ] c.paste[b (c.size*(1-t),  0),(1,0)+c.size*t,1] end]
transition[on BarnDoorIn     c a b t do BarnHoriz[c a b 0~t   t] end]
transition[on BarnDoorOut    c a b t do BarnHoriz[c b a 0~t 1-t] end]
transition[on BlinkIn        c a b t do BarnVert [c a b 0~t   t] end]
transition[on BlinkOut       c a b t do BarnVert [c b a 0~t 1-t] end]
transition[on SlitVertIn     c a b t do c.rect[(c.size/2,0)-(   t *c.size/2,0) (c.size*   t ,1)] c.merge[a b] end]
transition[on SlitVertOut    c a b t do c.rect[(c.size/2,0)-((1-t)*c.size/2,0) (c.size*(1-t),1)] c.merge[b a] end]
transition[on SlitHorizIn    c a b t do c.rect[(c.size/0,2)-(   t *c.size/0,2) (c.size*1,   t )] c.merge[a b] end]
transition[on SlitHorizOut   c a b t do c.rect[(c.size/0,2)-((1-t)*c.size/0,2) (c.size*1,(1-t))] c.merge[b a] end]

transition[on PageUp c a b t do
 c.rect[0,0 c.size*1,.5].merge[b a]
 if t<.5 i:t*2    c.paste[a.copy[c.size*0,.5 c.size*1,.5] (0,0,0,1)+(0,.5,1,(.5*1-i))*c.size]
 else    i:2*t-.5 c.paste[b.copy[c.size*0, 0 c.size*1,.5] (0,0,0,1)+(0,(.5*1-i),1,(.5*i))*c.size]
 end
end]
transition[on PageDown c a b t do
 c.rect[0,0 c.size*1,.5].merge[a b]
 if t<.5 i:t*2    c.paste[a.copy[c.size*0,.0 c.size*1,.5] (0,0,0,1)+(0,(.5*i),1,(.5*1-i))*c.size]
 else    i:2*t-.5 c.paste[b.copy[c.size*0,.5 c.size*1,.5] (0,0,0,1)+(0,.5,1,(.5*i))*c.size]
 end
end]
transition[on PageRight c a b t do
 c.rect[0,0 c.size*.5,1].merge[a b]
 if t<.5 i:t*2    c.paste[a.copy[c.size*.0,0 c.size*.5,1] (0,0,1,0)+((.5*i),0,(.5*1-i),1)*c.size]
 else    i:2*t-.5 c.paste[b.copy[c.size*.5,0 c.size*.5,1] (0,0,1,0)+(.5,0,(.5*i),1)*c.size]
 end
end]
transition[on PageLeft c a b t do
 c.rect[0,0 c.size*.5,1].merge[b a]
 if t<.5 i:t*2    c.paste[a.copy[c.size*.5,0 c.size*.5,1] (0,0,1,0)+(.5,0,(.5*1-i),1)*c.size]
 else    i:2*t-.5 c.paste[b.copy[c.size* 0,0 c.size*.5,1] (0,0,1,0)+((.5*1-i),0,(.5*i),1)*c.size]
 end
end]

transition[on Wink c a b t do
 s:if t<.5 c.paste[a] t else c.paste[b] 1-t end
 c.rect[       0,0 c.size*1, s]
 c.rect[c.size*0,1 c.size*1,-s]
end]

module.descs:raze insert k v with
 "PageDown"       "Stretch the source and destination like flipping a book page down."
 "PageUp"         "Stretch the source and destination like flipping a book page up."
 "PageRight"      "Stretch the source and destination like flipping a book page right."
 "PageLeft"       "Stretch the source and destination like flipping a book page left."
 "Dissolve"       "A randomized dissolve."
 "Melt"           "A smoothed noise dissolve."
 "BlindsVert"     "Vertical Venetian blinds."
 "BlindsHoriz"    "Horizontal Venetian blinds."
 "StarIn"         "Star-shaped zoom-in."
 "StarOut"        "Star-shaped zoom-out."
 "StarSpinIn"     "Spinning star-shaped zoom-in."
 "StarSpinOut"    "Spinning star-shaped zoom-out."
 "HeartIn"        "Heart-shaped zoom-in."
 "HeartOut"       "Heart-shaped zoom-out."
 "ClockIn"        "Clockwise pie-slice wipe."
 "ClockOut"       "Counter-clockwise pie-slice wipe."
 "CircleIn"       "Circle-shaped zoom-in."
 "CircleOut"      "Circle-shaped zoom-out."
 "CircleInClick"  "Circle-shaped zoom-in centered on the user's last click."
 "CircleOutClick" "Circle-shaped zoom-out centered on the user's last click."
 "StretchDown"    "Stretch the destination in from the top edge."
 "StretchUp"      "Stretch the destination in from the bottom edge."
 "StretchRight"   "Stretch the destination in from the left edge."
 "StretchLeft"    "Stretch the destination in from the right edge."
 "RotateDown"     "Stretch the source and destination like rotating a cube down."
 "RotateUp"       "Stretch the source and destination like rotating a cube up."
 "RotateRight"    "Stretch the source and destination like rotating a cube right."
 "RotateLeft"     "Stretch the source and destination like rotating a cube left."
 "Wink"           "Vertical squint to black, then unsquint to destination."
 "BarnDoorIn"     "Slide left and right halves apart vertically."
 "BarnDoorOut"    "Slide left and right halves together vertically."
 "BlinkIn"        "Slide top and bottom halves apart vertically."
 "BlinkOut"       "Slide top and bottom halves together vertically."
 "SlitVertIn"     "Merge in destination in a vertically opening slit."
 "SlitVertOut"    "Merge in destination in a vertically closing slit."
 "SlitHorizIn"    "Merge in destination in a horizontally opening slit."
 "SlitHorizOut"   "Merge in destination in a horizontally closing slit."
end
{end}

{contraption:wiggler}
size:[100,100]
resizable:1
margin:[5,5,5,5]
description:"a wiggly, squiggly animated drawing surface."
version:1.2
script:"wiggler.0p"
attributes:{"name":[],"label":[],"type":[]}
{widgets}
c:{"type":"canvas","size":[100,100],"pos":[0,0],"locked":1,"animated":1,"border":0,"scale":1}
br:{"type":"field","size":[100,20],"pos":[0,-44],"locked":1,"show":"none"}
fr:{"type":"field","size":[100,20],"pos":[0,-77],"locked":1,"show":"none","value":{"text":["","i","i","i"],"font":["","","",""],"arg":["","%%IMG2AGQAZAD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wA3","%%IMG2AGQAZAD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wA3","%%IMG2AGQAZAD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wD/AP8A/wA3"]}}
sh:{"type":"field","size":[100,20],"pos":[0,120],"locked":1,"show":"none","style":"plain","value":"%%IMG0ABUAFv8AePwAOPAAGOAACMAAAIAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAACAAACAAAGAAAOIAAeMAA+OAB+PgD+Pwf+A=="}
fl:{"type":"button","size":[60,20],"pos":[0,148],"locked":1,"style":"check"}
er:{"type":"field","size":[100,20],"pos":[114,120],"locked":1,"show":"none","style":"plain","value":"%%IMG0AAgAChw+f//////+/nw="}
mirror:{"type":"field","size":[100,20],"pos":[114,80],"locked":1,"show":"none","value":"[0,0]"}

{script:wiggler.0p}
delta:"%j"parse"[-2,-1,-1,0,1,1,2]"
on set_flip x do fl.value:x end
on set_hishape x do sh.data:image[x].map[1,0] end
on set_ershape x do er.data:image[x] end
on set_brush x do br.text:x end
on get_frames do fr.images end
on set_frames do fr.images:x end
on get_canv do c end
on set_mirrormode vh do mirror.data:vh end
on get_mirrormode do mirror.data end

on wig    x do return random[-1,0,1 2]+x end
on wiggle x do return random[delta  2]+x end

on draw x o frames do
 if "eraser"~br.text
  brush["Eraser" er.data]
  c.brush:"Eraser"
  c.pattern:0
  each f in frames
   c.paste[f]
   c.line[o x]
   f.paste[c.copy[]]
  end
  c.pattern:1
 elseif "hi"~2 take br.text
  pat:0+2 drop br.text
  img:image[sh.text]
  s:img.size
  y:x-s/2
  each f in frames
   w:wiggle[y]
   f.paste[img.copy[].merge[f.copy[w s].map[1 dict 1 pat]] w 1]
  end
 elseif "pen"~br.text
  c.brush:1
  each f in frames
   c.paste[f]
   c.line[o wig[x]]
   f.paste[c.copy[]]
  end
 elseif "pencil"~br.text
  c.brush:0
  each f in frames
   c.paste[f]
   c.line[wiggle[o] wiggle[x]]
   f.paste[c.copy[]]
  end
 else
  c.brush:br.text
  each f in frames
   c.paste[f]
   c.line[wiggle[o] wiggle[x]]
   f.paste[c.copy[]]
  end
 end
end

on drag x do
 if !card.locked
  m:mirror.data
  o:if pointer.down x else pointer.prev-card.offset end
  frames:get_frames[]
  fs:(first frames).size
  draw[x o frames]

  # mirrored drawing:
  if m[0]  draw[(x[0],(fs[1]-x[1])) (o[0],(fs[1]-o[1])) frames] end
  if m[1]  draw[((fs[0]-x[0]),x[1]) ((fs[0]-o[0]),o[1]) frames] end
  if m~1,1 draw[(fs-x)              (fs-o)              frames] end

  if !app.playing
   pensounds:"%j"parse"{l}
    'Blobby'     :['wipe1','wipe2','wipe3'],
    'eraser'     :['erase1','erase2'],
    'StippleTiny':['stip1','stip2','stip3'],
    'pencil'     :['pencil1','pencil2'],
    'SoftLrg'    :['spray1','spray2'],
    'pen'        :['pen1','pen2'],
   {r}"
   play[random[("squeak1","squeak2") unless pensounds[br.text]]]
  end
 end
end

on click x do
 card.event["begin"]
 drag[x]
end

on view do
 frames:get_frames[]
 each f in frames f.size:card.size end
 c.show:card.show
 c.clear[]
 i:frames[3%sys.frame/5] 
 c.paste[if fl.value i.copy[].transform["horiz"] else i end]
end

on get_animate do
 on animate do view[] end
end
{end}

{contraption:popOut}
size:[101,148]
resizable:1
margin:[0,0,0,0]
description:"A sliding animated element that alternates between two positions when clicked."
script:"popOut.0p"
template:"on click do\n \nend"
attributes:{"name":["img","speed","value"],"label":["Image","Speed","Value"],"type":["rich","number","bool"]}
{widgets}
c:{"type":"canvas","size":[26,26],"pos":[37,0],"locked":1,"border":0}
v:{"type":"button","size":[60,20],"pos":[114,2],"show":"none","style":"check","value":0}
t:{"type":"field","size":[64,20],"pos":[113,31],"show":"none","style":"plain","value":"0"}
i:{"type":"field","size":[66,20],"pos":[113,61],"show":"none","value":{"text":["","i"],"font":["",""],"arg":["","%%IMG2ABoAGgABARgAAQH/Af8BcgABARgAAQ=="]}}
s:{"type":"field","size":[100,20],"pos":[112,90],"show":"none","style":"plain","value":"1"}

{script:popOut.0p}
on get_value do v.value end
on set_value x do v.value:x view[] end
on get_img do i.value end
on set_img x do i.value:x view[] end
on get_speed do 0+s.text end
on set_speed x do s.text:0|x end

on click do
 set_value[!get_value[]]
 card.event["click"]
end
on tween a b t do
 # see easeInOutBack() from easings.net
 c1:1.70158 c2:1.525
 a+(b-a)*.5*if !t>.5
    ((2*t    )^2)*((c2+1)*(   2*t))-c2
 else
  2+(((2*t)-2)^2)*((c2+1)*(-2+2*t))+c2
 end
end
on view do
 img:first i.images
 c.size:img.size
 c.show:card.show
 c.paste[img]
 tn:0+t.text
 chg:if tn>v.value -1 elseif v.value>tn 1 else 0 end
 t.text:0|1&tn+chg*0.03*s.text
 c.animated:!tn~v.value
 d:card.size-c.size
 a:d[1]>d[0]
 tw:tween[2 d[a]-2 tn]
 ct:d[!a]/2
 c.pos:if a ct,tw else tw,ct end
end
{end}

{contraption:imageEnum}
size:[100,100]
resizable:1
margin:[17,3,18,5]
description:"select from among enumerated image values."
version:1
script:"imageEnum.0p"
template:"on change img index do\n \nend"
attributes:{"name":["options"],"label":["Options"],"type":["rich"]}
{widgets}
s:{"type":"slider","size":[100,100],"pos":[0,0],"interval":[0,0],"style":"compact"}
c:{"type":"canvas","size":[70,96],"pos":[15,2],"locked":1,"border":0,"scale":1}
o:{"type":"field","size":[44,53],"pos":[129,-20],"locked":1,"show":"none"}

{script:imageEnum.0p}
on get_options do o.value end
on set_options x do o.value:x view[] x end
on get_value do o.images[s.value] end
on get_valueIndex do s.value end
on set_valueIndex x do s.value:x view[] x end

on view do
 im:o.images
 i:im[s.value]
 s.interval:0,0|(count im)-1
 s.locked:card.locked
 s.show  :card.show
 c.show  :card.show
 c.clear[]
 c.paste[i .5*c.size-i.size 1]
end

on change do
 card.event["change" get_value[] s.value]
 view[]
end
{end}

{contraption:animButton}
size:[100,100]
resizable:1
margin:[1,1,1,1]
description:"A graphical drop-in replacement for buttons."
version:1.2
script:"animButton.0p"
template:"on click do\n \nend\n\non finish do\n \nend"
attributes:{"name":["images"],"label":["Images"],"type":["rich"]}
{widgets}
c:{"type":"canvas","size":[100,100],"pos":[0,0],"locked":1,"volatile":1,"border":0,"scale":1}
b:{"type":"button","size":[100,100],"pos":[0,0],"script":"animButton.1p","show":"transparent","style":"invisible"}
ims:{"type":"field","size":[100,20],"pos":[121,5],"show":"none","border":1}
ai:{"type":"field","size":[100,20],"pos":[121,37],"show":"none","style":"plain"}

{script:animButton.0p}
on view do
 i:ims.images
 f:first i
 c.show:card.show
 c.clear[]
 if c.animated
  s:(range count i),1 drop rev range count i
  a:floor ai.text/2
  f:f unless i[s[a]]
  if a~(count s)-1 c.animated:b.locked:0 card.event["finish"]
  else ai.text:1+ai.text end
 end
 c.paste[f .5*c.size-f.size]
end

on click do
 if !b.locked
  ai.text:0
  c.animated:b.locked:1
  view[]
  card.event["click"]
 end
end

on get_images do ims.value end
on set_images x do ims.value:x end
{end}

{script:animButton.1p}
on click do end
{end}

