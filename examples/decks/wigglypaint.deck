mvert:{"type":"button","size":[64,30],"pos":[442,251],"script":"alter.8","text":"Flip Vert","value":0}
reset:{"type":"button","size":[82,30],"pos":[123,316],"script":"alter.9","style":"invisible"}
shift:{"type":"field","size":[18,10],"pos":[475,23],"show":"none","value":"[0,0]"}
apply:{"type":"button","size":[134,57],"pos":[379,290],"script":"alter.10","style":"invisible"}
cancel:{"type":"contraption","size":[109,42],"pos":[-1,299],"script":"alter.11","show":"transparent","def":"animButton","widgets":{"c":{"size":[109,42],"show":"transparent"},"b":{"size":[109,42]},"ims":{"size":[100,9],"pos":[130,2],"value":{"text":["","i","i"],"font":["","",""],"arg":["","%%","%%"]}},"ai":{"size":[100,8],"pos":[130,16],"value":"4"}}}

{script:alter.0}
on init do
 reset.event.click
end

on changemargin do
 play.click
 view[]
end

on shiftcanvas offset do
 play.click
 shift.data:((0,0) unless shift.data)+5*offset
 view[]
end

on navigate dir do
 deltas.up   : 0,-1
 deltas.down : 0, 1
 deltas.left :-1, 0
 deltas.right: 1, 0
 shiftcanvas[deltas[dir]]
end

on getframe do
 (first main.widgets.target.frames).copy[]
end

on scrungle img do
 if uncrop.value
  local t:image[dims.size]
  t.paste[img .5*t.size-img.size]
  img:t
 end
 img.translate[shift.data 1]
 if mvert.value  img.transform.vert  end
 if mhoriz.value img.transform.horiz end
 img
end

on view do
 t:main.widgets.target
 f:scrungle[getframe[]]
 top   .interval:0,f.size[1]
 bottom.interval:0,f.size[1]
 left  .interval:f.size[0],0
 right .interval:f.size[0],0
 mvert .show:("solid","invert")[mvert .value]
 mhoriz.show:("solid","invert")[mhoriz.value]

 preview.size:f.size
 preview.pos:dims.pos+(dims.size-preview.size)/2
 preview.show:if options.widgets.mask.value "transparent" else "solid" end
 preview.paste[f 1]
 preview.pattern:255 # ANTS!
 preview.line[left.value,0 left.value,f.size[1]]
 preview.line[0,top.value  f.size[0],top.value ]
 preview.line[(f.size[0]-right.value),0  (f.size[0]-right.value),f.size[1]]
 preview.line[0,(f.size[1]-bottom.value) f.size[0],(f.size[1]-bottom.value)]
 
 fit.locked:(list 0)~keys f.hist
 uncrop.locked:dims.size~f.size
end
{end}

{script:alter.1}
on change val do
 changemargin[]
end
{end}

{script:alter.2}
on click do
 shiftcanvas[0,-1]
end
{end}

{script:alter.3}
on click do
 shiftcanvas[-1,0]
end
{end}

{script:alter.4}
on click do
 shiftcanvas[0,1]
end
{end}

{script:alter.5}
on click do
 shiftcanvas[1,0]
end
{end}

{script:alter.6}
on tween t a b do
 a+(b-a)*t^2
end

on click do
 top   .value:0
 left  .value:0
 right .value:0
 bottom.value:0
 f:scrungle[main.widgets.target.frames[0].copy[]]
 w:f.size[0]
 h:f.size[1]
 on scan ctrl lim rect size step do
  done:0
  v:ctrl.value
  while (!done)&v<lim
   if 1<count keys f.copy[rect size].hist
    done:1
   else
    v:v+1
    rect:rect+step
   end
  end
  each t in range 11
   ctrl.value:tween[t/10 ctrl.value v]
   play["click"]
   view[]
   sleep[]
  end
 end
 scan[left   w (   0 ,   0 ) (1,h) ( 1, 0)]
 scan[right  w ((w-2),   0 ) (1,h) (-1, 0)]
 scan[top    h (   0 ,   0 ) (w,1) ( 0, 1)]
 scan[bottom h (   0 ,(h-2)) (w,1) ( 0,-1)]
end
{end}

{script:alter.7}
on click do
 play.pencil1
 me.value:!me.value
 view[]
end
{end}

{script:alter.8}
on click do
 play.pencil2
 me.value:!me.value
 view[]
end
{end}

{script:alter.9}
on click do
 play["pick"]
 top   .value:0
 left  .value:0
 right .value:0
 bottom.value:0
 mvert .value:0
 mhoriz.value:0
 shift.data:0,0
 uncrop.value:0
 view[]
end
{end}

{script:alter.10}
on click do
 t:main.widgets.target
 p:left.value,top.value
 m:right.value,bottom.value
 s:preview.size-p+m
 main.event.backup
 main.event["setframes"
  each frame in t.frames
   scrungle[frame.copy[]].copy[p s]
  end
 ]
 t.animate[]
 play.scratch
 go[main "BoxOut" 15]
end
{end}

{script:alter.11}
on finish do
 play["cancel"]
 go["main" "BoxOut" 15]
end
{end}

