names:{"type":"grid","size":[180,120],"pos":[278,113],"locked":1,"script":"home.1","scrollbar":1,"headers":1,"lines":0,"value":{"Function Name":["lerp","inSine","outSine","inOutSine","inQuad","outQuad","inOutQuad","inCubic","outCubic","inOutCubic","inQuart","outQuart","inOutQuart","inQuint","outQuint","inOutQuint","inExpo","outExpo","inOutExpo","inCirc","outCirc","inOutCirc","inBack","outBack","inOutBack","inElastic","outElastic","inOutElastic","inBounce","outBounce","inOutBounce","spline","spline_at"]},"scroll":18,"row":24}
