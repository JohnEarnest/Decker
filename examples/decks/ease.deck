{script:home.0}
on view do
 version.text:"v%0.1f" format deck.modules.ease.version
 names.value:select "Function Name":key from ease
 name:first names.rowvalue
 usage.text:"ease.%s[time a b]" format name
 
 m:20
 i:c.size-2*m
 f:ease[name]
 c.clear[]
 c.brush:4
 c.pattern:13
 c.line[each t in range i[0]
  (m+t),(f[t/i[0] m+i[1] m])
 end]
 c.brush:0
 c.pattern:1
 c.line[m,m m,c.size[1]-m c.size-m]
end
{end}

{script:home.1}
on click do
 view[]
end
{end}

{script:home.2}
on click do
 go["splining" "BoxIn" 15]
end
{end}

{card:splining}
script:"splining.0"
{widgets}
button1:{"type":"button","size":[76,20],"pos":[18,306],"script":"splining.1","text":"Index"}
field1:{"type":"field","size":[241,36],"pos":[148,16],"locked":1,"font":"deckbuilder","border":0,"style":"plain","align":"center","value":"Catmull-Rom Splines"}
target:{"type":"canvas","size":[220,220],"pos":[30,67],"locked":1,"volatile":1,"pattern":35,"scale":1}
c1:{"type":"canvas","size":[16,16],"pos":[158,86],"locked":1,"volatile":1,"script":"splining.2","show":"transparent","border":1,"draggable":1,"scale":1}
c2:{"type":"canvas","size":[16,16],"pos":[83,153],"locked":1,"volatile":1,"script":"splining.2","show":"transparent","border":1,"draggable":1,"scale":1}
c3:{"type":"canvas","size":[16,16],"pos":[189,148],"locked":1,"volatile":1,"script":"splining.2","show":"transparent","border":1,"draggable":1,"scale":1}
c4:{"type":"canvas","size":[16,16],"pos":[191,249],"locked":1,"volatile":1,"script":"splining.2","show":"transparent","border":1,"draggable":1,"scale":1}
c5:{"type":"canvas","size":[16,16],"pos":[76,234],"locked":1,"volatile":1,"script":"splining.2","show":"transparent","border":1,"draggable":1,"scale":1}
field2:{"type":"field","size":[220,14],"pos":[30,53],"locked":1,"border":0,"align":"center","value":"drag the control points to update the spline!"}
field3:{"type":"field","size":[234,148],"pos":[265,67],"locked":1,"value":"Catmull-Rom splines create a smooth curve which follows a series of \"control points\". \n\nThe ease.spline[controls steps] function produces a list of points which follow control points using uniform divisions (an integer \"steps\" per division) between each control point. This is handy for directly plotting a spline.\n\nThe ease.spline_at[controls indices] takes a number or list of numbers \"indices\"- each between 0 and 1- and samples the spline at that percentage along its entire path. This is handy for controlling animation with a spline."}
field4:{"type":"field","size":[234,24],"pos":[265,217],"locked":1,"border":0,"align":"center","value":"View the card script\nto see how these examples work!"}
slider:{"type":"slider","size":[234,25],"pos":[265,262],"volatile":1,"script":"splining.3","interval":[0,1],"step":0.01}

{script:splining.0}
on view do
 # calculate control points based on the center of each
 # draggable canvas, offset to the origin of the drawing canvas:
 p:((c1,c2,c3,c4,c5)..pos)-list (-c1.size/2)+target.pos
 
 target.clear[]
 
 # draw a spline through the control points,
 # with 10 steps between each control point:
 target.pattern:1
 target.brush:2
 target.line[ease.spline[p 10]]
 
 # sample a position along the spline based
 # on an interactive slider:
 target.pattern:colors.red
 target.brush:4
 target.line[ease.spline_at[p slider.value]]
 
 # sample multiple points leading up to the slider value:
 target.brush:0
 target.line[ease.spline_at[p slider.value*.01*range 100]]
end
{end}

{script:splining.1}
on click do
 go["home" "BoxOut" 15]
end
{end}

{script:splining.2}
on drag    do view[] end
on release do view[] end
{end}

{script:splining.3}
on change do
 view[]
end
{end}

{module:ease}
description:"a collection of easing functions"
version:1.1
{script}
on tween f do
 # for ease of use (har har), wrap all the basic
 # easing functions with clamping and interpolation:
 on ease t a b do a+(b-a)*f[0|1&t] end
end

module.lerp:tween[on lerp x do x end]

module.inSine    :tween[on inSine    x do 1-cos.5*pi*x end]
module.outSine   :tween[on outSine   x do sin.5*pi*x end]
module.inOutSine :tween[on inOutSine x do -.5*-1+cos pi*x end]

module.inQuad    :tween[on inQuad    x do x^2 end]
module.outQuad   :tween[on outQuad   x do 1-(1-x)^2 end]
module.inOutQuad :tween[on inOutQuad x do if x<.5 2*x^2 else 1-.5*(2+-2*x)^2 end end]

module.inCubic   :tween[on inCubic    x do x^3 end]
module.outCubic  :tween[on outCubic   x do 1-(1-x)^3 end]
module.inOutCubic:tween[on inOutCubic x do if x<.5 4*x^3 else 1-.5*(2+-2*x)^3 end end]

module.inQuart   :tween[on inQuart    x do x^4 end]
module.outQuart  :tween[on outQuart   x do 1-(1-x)^4 end]
module.inOutQuart:tween[on inOutQuart x do if x<.5 8*x^4 else 1-.5*(2+-2*x)^4 end end]

module.inQuint   :tween[on inQuint    x do x^5 end]
module.outQuint  :tween[on outQuint   x do 1-(1-x)^5 end]
module.inOutQuint:tween[on inOutQuint x do if x<.5 16*x^5 else 1-.5*(2+-2*x)^5 end end]

module.inExpo    :tween[on inExpo     x do 2^-10+10*x end]
module.outExpo   :tween[on outExpo    x do 1-2^-10*x end]
module.inOutExpo :tween[on inOutExpo  x do .5*if x<.5 2^-10+20*x else 2-2^10+-20*x end end]

module.inCirc    :tween[on inCirc     x do 1-sqrt 1-x^2 end]
module.outCirc   :tween[on outCirc    x do sqrt 1-(x-1)^2 end]
module.inOutCirc :tween[on inOutCirc  x do .5*if x<.5 1-sqrt 1-(2*x)^2 else 1+sqrt 1-(2+-2*x)^2 end end]

c1:1.70158
c2:c1*1.525
c3:c1+1
module.inBack      :tween[on inBack     x do (c3*x^3)-(c1*x^2) end]
module.outBack     :tween[on outBack    x do 1+(c3*(x-1)^3)+(c1*(x-1)^2) end]
module.inOutBack   :tween[on inOutBack  x do .5*if x<.5 ((2*x)^2)*((c2+1)*(2*x))-c2 else 2+(((2*x)-2)^2)*((c2+1)*(-2+2*x))+c2 end end]

c4:(2*pi)/3
c5:(2*pi)/4.5
module.inElastic   :tween[on inElastic    x do (- 2^-10+10*x)*(sin c4*-10.75+10*x) end]
module.outElastic  :tween[on outElastic   x do 1+(2^-10*x)*(sin c4*-.75+10*x) end]
module.inOutElastic:tween[on inOutElastic x do t:sin c5*-11.125+20*x if x<.5 .5*-t*(2^-10+20*x) else 1+.5*t*(2^10+-20*x) end end]

n1:7.5625 d1:2.75
on outBounce x do
 if     x<1  /d1                      n1*x^2
 elseif x<2  /d1 x:x-1.500/d1 .750000+n1*x^2
 elseif x<2.5/d1 x:x-2.250/d1 .937500+n1*x^2
 else            x:x-2.625/d1 .984375+n1*x^2 end 
end
module.inBounce   :tween[on inBounce    x do 1-outBounce[1-x] end]
module.outBounce  :tween[outBounce]
module.inOutBounce:tween[on inOutBounce x do .5*if x<.5 1-outBounce[1-2*x] else 1+outBounce[-1+2*x] end end]

local cr_basis: .5 * "%j" parse "[[0,2,0,0],[-1,0,1,0],[2,-5,4,-1],[-1,3,-3,1]]"

module.spline:on spline controls divisions do
 local segs: -4 window (list first controls),controls,(list last controls)
 local tween: (4 take list (range divisions+1)/divisions)^range 4
 raze each segment in segs
  flip each axis in flip segment
   sum tween * sum @ cr_basis * list axis
  end
 end
end

module.spline_at:on spline_at controls indices do
 local segs: -4 window (list first controls),controls,(list last controls)
 local ix:0|1&if "number"~typeof indices list indices else indices end
 local n: count segs
 local wi: (n-1)&floor ix*n   # window index
 local wt: (ix=1)+1%ix*n # tween within window
 local r:raze each segment i in segs @ wi
  local tween: wt[i]^range 4
  flip each axis in flip segment
   sum tween * sum @ cr_basis * list axis
  end
 end
 if "number"~typeof indices first r else r end
end
{end}

